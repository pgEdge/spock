{
  "workflow_name": "Cross Wire 2 spock Nodes",
  "description": "Cross Wire two spock nodes with replication slots and replication sets.",
  "steps": [
    {
      "spock": {
        "node": "n1",
        "command": "CREATE NODE",
        "description": "Create a spock node",
        "args": [
          "--node=n1",
          "--db=pgedge",
          "--node_name=n1",
          "--dsn=host=127.0.0.1 port=5432 user=pgedge password=pgedge",
          "--location=location1",
          "--country=country1",
          "--info={\"key\": \"value\"}"
        ],
        "on_success": {},
        "on_failure": {}
      }
    },
    {
      "spock": {
        "node": "n2",
        "command": "CREATE NODE",
        "description": "Create a spock node",
        "args": [
          "--node=n2",
          "--db=pgedge",
          "--node_name=n2",
          "--dsn=host=127.0.0.1 port=5433 user=pgedge password=pgedge",
          "--location=location2",
          "--country=country2",
          "--info={\"key\": \"value\"}"
        ],
        "on_success": {},
        "on_failure": {}
      }
    },
    {
      "spock": {
        "node": "n1",
        "command": "CREATE SUBSCRIPTION",
        "description": "Create a subscription for n1",
        "args": [
          "--node=n1",
          "--db=pgedge",
          "--sub_name=sub1",
          "--provider_dsn=host=127.0.0.1 port=5433 user=pgedge password=spockpass",
          "--db=pgedge",
          "--replication_sets=ARRAY['default', 'default_insert_only', 'ddl_sql']",
          "--synchronize_structure=false",
          "--synchronize_data=false",
          "--forward_origins='{}'::text[]",
          "--apply_delay='0'::interval"
        ],
        "on_success": {},
        "on_failure": {}
      }
    },
    {
      "spock": {
        "node": "n2",
        "command": "CREATE SUBSCRIPTION",
        "description": "Create a subscription for n2",
        "args": [
          "--node=n2",
          "--db=pgedge",
          "--sub_name=sub2",
          "--provider_dsn=host=127.0.0.1 port=5432 user=pgedge password=pgedge",
          "--db=pgedge",
          "--replication_sets=ARRAY['default', 'default_insert_only', 'ddl_sql']",
          "--synchronize_structure=false",
          "--synchronize_data=false",
          "--forward_origins='{}'::text[]",
          "--apply_delay='0'::interval"
        ],
        "on_success": {},
        "on_failure": {}
      }
    }
  ]
}