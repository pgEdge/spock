{
  "workflow_name": "Uncross Wire 2 spock Nodes",
  "description": "Uncross Wire two spock nodes by dropping replication slots and replication sets.",
  "steps": [
    {
      "spock": {
        "node": "n1",
        "command": "DROP REPLICATION SET",
        "description": "Drop the replication set for n1",
        "args": [
          "--db=pgedge",
          "--set_name=test_set"
        ],
        "on_success": {},
        "on_failure": {}
      }
    },
    {
      "spock": {
        "node": "n2",
        "command": "DROP REPLICATION SET",
        "description": "Drop the replication set for n2",
        "args": [
          "--db=pgedge",
          "--set_name=test_set"
        ],
        "on_success": {},
        "on_failure": {}
      }
    },
    {
      "spock": {
        "node": "n1",
        "command": "DROP SUBSCRIPTION",
        "description": "Drop the subscription for n1",
        "args": [
          "--db=pgedge",
          "--sub_name=sub1",
          "--db=pgedge"
        ],
        "on_success": {},
        "on_failure": {}
      }
    },
    {
      "spock": {
        "node": "n2",
        "command": "DROP SUBSCRIPTION",
        "description": "Drop the subscription for n2",
        "args": [
          "--db=pgedge",
          "--sub_name=sub2",
          "--db=pgedge"
        ],
        "on_success": {},
        "on_failure": {}
      }
    },
    {
      "spock": {
        "node": "n2",
        "command": "DROP NODE",
        "description": "Drop the spock node n2",
        "args": [
          "--db=pgedge",
          "--node_name=n2",
          "--db=pgedge"
        ],
        "on_success": {},
        "on_failure": {}
      }
    },
    {
      "spock": {
        "node": "n1",
        "command": "DROP NODE",
        "description": "Drop the spock node n1",
        "args": [
          "--node=n1",
          "--db=pgedge",
          "--node_name=n1"
        ],
        "on_success": {},
        "on_failure": {}
      }
    }
  ]
}
