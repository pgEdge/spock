\c :provider_dsn
\set VERBOSITY terse
-- Check propagation of security labels
CREATE TABLE slabel1 (x integer, y text PRIMARY KEY);
INFO:  DDL statement replicated.
SELECT spock.delta_apply('slabel1', 'x');
INFO:  DDL statement replicated.
 delta_apply 
-------------
